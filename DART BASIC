Basic Object-Oriented Programming (OOP)
Class & Object
class Person {
  String name;
  int age;

  Person(this.name, this.age);

  void display() {
    print("$name is $age years old");
  }
}

void main() {
  var p = Person("Aalok", 22);
  p.display();
}
Encapsulation
class Bank {
  double _balance = 0;

  void deposit(double amount) {
    _balance += amount;
  }

  double get balance => _balance;
}
Inheritance
class Animal {
  void sound() {
    print("Animal sound");
  }
}

class Dog extends Animal {}
Polymorphism
class Animal {
  void sound() {
    print("Animal sound");
  }
}

class Cat extends Animal {
  @override
  void sound() {
    print("Cat meows");
  }
}
Abstraction
abstract class Shape {
  void draw();
}

class Circle extends Shape {
  @override
  void draw() {
    print("Drawing Circle");
  }
}


